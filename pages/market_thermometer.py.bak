def market_thermometer_page():
    """市场温度计页面"""
    st.title("🌡️ 市场温度计")
    st.info("📊 多维度分析：价格位置 + 涨跌幅 + 成交额占比（情绪指标）")

    # 温度说明
    with st.expander("📖 温度等级说明"):
        col1, col2, col3 = st.columns(3)
        with col1:
            st.markdown("**🥶 0-15°C 冰冷**")
            st.markdown("**🧊 15-30°C 寒冷**")
        with col2:
            st.markdown("**🌤️ 30-45°C 凉爽**")
            st.markdown("**😊 45-60°C 温和**")
        with col3:
            st.markdown("**🔥 60-75°C 炎热**")
            st.markdown("**🌋 75-100°C 滚烫**")

        st.divider()
        st.markdown("**💡 成交额占比说明**")
        st.markdown("- **≥40%**: ⚠️ 极度拥挤，强烈建议止盈")
        st.markdown("- **30-40%**: 🔥 非常活跃，建议谨慎")
        st.markdown("- **20-30%**: 📈 活跃，资金关注度高")
        st.markdown("- **10-20%**: 😐 正常范围")
        st.markdown("- **<10%**: ❄️ 冷清，关注度低")

    # 标签页
    tab1, tab2, tab3 = st.tabs(["📈 主要指数", "🏭 行业板块(多维度)", "📊 我的持仓"])

    with tab1:
        st.subheader("主要市场指数温度")

        indices = get_benchmark_indices()

        with st.spinner("正在分析指数温度..."):
            temperatures = []
            for idx in indices:
                result = calculate_market_temperature(idx['code'], idx['name'])
                if result:
                    temperatures.append(result)

        if temperatures:
            temperatures.sort(key=lambda x: x['temperature'], reverse=True)

            data = []
            for temp in temperatures:
                data.append({
                    '指数': temp['fund_name'],
                    '代码': temp['fund_code'],
                    '温度': temp['temperature'],
                    '状态': f"{temp['icon']} {temp['heat_level']}",
                    '近1周': f"{temp['metrics']['week_return']:+.2f}%",
                    '近1月': f"{temp['metrics']['month_return']:+.2f}%",
                    '价格位置': f"{temp['metrics']['price_position']:.1f}%",
                    '回撤': f"{temp['metrics']['current_drawdown']:.2f}%"
                })

            st.dataframe(pd.DataFrame(data), use_container_width=True, hide_index=True)

    with tab2:
        st.subheader("行业板块多维度温度分析")
        st.caption("结合价格走势和成交额占比，更准确判断市场情绪")

        include_volume = st.checkbox("📊 包含成交额分析（推荐）", value=True,
                                     help="获取东方财富行业资金流向数据")

        sectors = get_sector_etfs()

        fund_flow_data = None

        if include_volume:
            with st.spinner("正在获取行业资金流向数据..."):
                fund_flow_data, _ = get_sector_fund_flow_data()

        with st.spinner("正在分析行业温度..."):
            sector_temps = []
            for sector in sectors:
                result = calculate_market_temperature(
                    sector['code'],
                    sector['name'],
                    include_volume=include_volume,
                    fund_flow_data=fund_flow_data
                )
                if result:
                    sector_temps.append(result)

        if sector_temps:
            sector_temps.sort(key=lambda x: x['temperature'], reverse=True)

            # 预警
            if include_volume and fund_flow_data:
                high_volume_sectors = [s for s in sector_temps if s.get('volume_ratio', 0) > 20]
                if high_volume_sectors:
                    st.warning(f"⚠️ {len(high_volume_sectors)} 个行业成交额占比超过20%，警惕情绪过热！")

            # 热力图
            st.subheader("🌡️ 行业热力分布")
            cols = st.columns(4)

            for i, sector in enumerate(sector_temps):
                col = cols[i % 4]

                with col:
                    delta_str = sector['heat_level']
                    if include_volume and 'volume_ratio' in sector:
                        delta_str += f" | 占比: {sector['volume_ratio']:.1f}%"

                    st.metric(
                        label=f"{sector['icon']} {sector['fund_name']}",
                        value=f"{sector['temperature']}°C",
                        delta=delta_str
                    )

                    if include_volume and 'volume_sentiment' in sector:
                        net_inflow_str = ""
                        if 'net_inflow' in sector:
                            inflow = sector['net_inflow']
                            if inflow > 0:
                                net_inflow_str = f" | 净流入: +{inflow:.1f}万"
                            elif inflow < 0:
                                net_inflow_str = f" | 净流出: {inflow:.1f}万"
                        st.caption(f"📊 {sector['volume_sentiment']}{net_inflow_str}")

                    st.caption(
                        f"近1月: **{sector['metrics']['month_return']:+.1f}%** | "
                        f"位置: {sector['metrics']['price_position']:.0f}%"
                    )

            st.divider()

            # 资金流向排行
            if include_volume and fund_flow_data:
                st.subheader("📊 成交额占比排行榜")

                volume_sorted = sorted(
                    [s for s in sector_temps if 'volume_ratio' in s],
                    key=lambda x: x['volume_ratio'],
                    reverse=True
                )

                col1, col2 = st.columns(2)

                with col1:
                    st.markdown("#### 🔥 资金追捧TOP5")
                    for s in volume_sorted[:5]:
                        st.metric(
                            f"{s['fund_name']}",
                            f"{s['volume_ratio']:.1f}%",
                            delta=s.get('volume_sentiment', '')
                        )

                with col2:
                    st.markdown("#### ❄️ 资金冷清TOP5")
                    for s in volume_sorted[-5:]:
                        st.metric(
                            f"{s['fund_name']}",
                            f"{s['volume_ratio']:.1f}%",
                            delta=s.get('volume_sentiment', '')
                        )

            st.divider()

            # 温度分类
            boiling = [s for s in sector_temps if s['temperature'] > 75]
            hot = [s for s in sector_temps if 60 < s['temperature'] <= 75]
            warm = [s for s in sector_temps if 45 <= s['temperature'] <= 60]
            cool = [s for s in sector_temps if 30 <= s['temperature'] < 45]
            cold = [s for s in sector_temps if s['temperature'] < 30]

            col1, col2, col3, col4, col5 = st.columns(5)

            with col1:
                st.markdown("#### 🌋 滚烫\n(>75°C)")
                for s in boiling[:3]:
                    st.metric(s['fund_name'], f"{s['temperature']}°C")
                if not boiling:
                    st.caption("无")

            with col2:
                st.markdown("#### 🔥 炎热\n(60-75°C)")
                for s in hot[:3]:
                    st.metric(s['fund_name'], f"{s['temperature']}°C")
                if not hot:
                    st.caption("无")

            with col3:
                st.markdown("#### 😊 温和\n(45-60°C)")
                for s in warm[:3]:
                    st.metric(s['fund_name'], f"{s['temperature']}°C")
                if not warm:
                    st.caption("无")

            with col4:
                st.markdown("#### 🌤️ 凉爽\n(30-45°C)")
                for s in cool[:3]:
                    st.metric(s['fund_name'], f"{s['temperature']}°C")
                if not cool:
                    st.caption("无")

            with col5:
                st.markdown("#### 🥶 寒冷\n(<30°C)")
                for s in cold[:3]:
                    st.metric(s['fund_name'], f"{s['temperature']}°C")
                if not cold:
                    st.caption("无")

            st.divider()

            # 详情表格
            st.subheader("📋 行业温度详情")

            data = []
            for temp in sector_temps:
                row_data = {
                    '行业': temp['fund_name'],
                    '代码': temp['fund_code'],
                    '温度': temp['temperature'],
                    '状态': f"{temp['icon']} {temp['heat_level']}",
                    '近1周': f"{temp['metrics']['week_return']:+.2f}%",
                    '近1月': f"{temp['metrics']['month_return']:+.2f}%",
                    '价格位置': f"{temp['metrics']['price_position']:.1f}%"
                }

                if include_volume and 'volume_ratio' in temp:
                    row_data['成交额占比'] = f"{temp['volume_ratio']:.1f}%"

                    if 'net_inflow' in temp:
                        inflow = temp['net_inflow']
                        if inflow > 0:
                            row_data['资金净流入'] = f"+{inflow:.1f}万"
                        elif inflow < 0:
                            row_data['资金净流入'] = f"{inflow:.1f}万"
                        else:
                            row_data['资金净流入'] = "0"

                    row_data['情绪'] = temp.get('volume_sentiment', '-')

                data.append(row_data)

            st.dataframe(pd.DataFrame(data), use_container_width=True, hide_index=True)

    with tab3:
        st.subheader("我的持仓温度")

        holdings = get_holdings()

        if not holdings:
            st.warning("⚠️ 暂无持仓，请先买入基金")
            return

        with st.spinner("正在分析持仓温度..."):
            holding_temps = []
            for h in holdings:
                result = calculate_market_temperature(h['fund_code'], h['fund_name'])
                if result:
                    result['current_value'] = h['current_value']
                    result['profit_loss'] = h['profit_loss']
                    result['profit_loss_ratio'] = h['profit_loss_ratio']
                    holding_temps.append(result)

        if holding_temps:
            holding_temps.sort(key=lambda x: x['temperature'], reverse=True)

            avg_temp = sum(h['temperature'] for h in holding_temps) / len(holding_temps)
            hot_count = sum(1 for h in holding_temps if h['temperature'] > 60)
            cold_count = sum(1 for h in holding_temps if h['temperature'] < 40)

            col1, col2, col3, col4 = st.columns(4)
            with col1:
                st.metric("平均温度", f"{avg_temp:.1f}°C")
            with col2:
                st.metric("高温基金", hot_count, ">60°C")
            with col3:
                st.metric("低温基金", cold_count, "<40°C")
            with col4:
                total_value = sum(h['current_value'] for h in holding_temps)
                hot_value = sum(h['current_value'] for h in holding_temps if h['temperature'] > 60)
                st.metric("高温占比", f"{hot_value/total_value*100:.1f}%")

            st.divider()

            data = []
            for temp in holding_temps:
                pl_emoji = "🔴" if temp['profit_loss'] > 0 else "🟢"
                data.append({
                    '基金': temp['fund_name'],
                    '温度': temp['temperature'],
                    '状态': f"{temp['icon']} {temp['heat_level']}",
                    '市值': f"¥{temp['current_value']:.0f}",
                    '盈亏': f"{pl_emoji} {temp['profit_loss']:+.0f} ({temp['profit_loss_ratio']:+.1f}%)",
                    '近1月': f"{temp['metrics']['month_return']:.2f}%"
                })

            st.dataframe(pd.DataFrame(data), use_container_width=True, hide_index=True)

            st.divider()
            st.subheader("💡 温度分析建议")

            if avg_temp < 30:
                st.success("🟢 **市场偏冷** - 可能是较好的加仓时机")
            elif avg_temp < 50:
                st.info("🔵 **市场温和** - 建议保持正常定投节奏")
            elif avg_temp < 70:
                st.warning("🟠 **市场偏热** - 建议谨慎追高，可适当止盈")
            else:
                st.error("🔴 **市场过热** - 建议控制仓位，注意风险")

            st.divider()
            st.subheader("🎯 个别基金建议")

            hot_funds = [h for h in holding_temps if h['temperature'] >= 75]
            cold_funds = [h for h in holding_temps if h['temperature'] <= 20]

            if hot_funds:
                for temp in hot_funds:
                    st.warning(f"⚠️ **{temp['fund_name']}** 温度过高，建议关注止盈机会")

            if cold_funds:
                for temp in cold_funds:
                    st.info(f"📌 **{temp['fund_name']}** 温度较低，可考虑逢低补仓")

            if not hot_funds and not cold_funds:
                st.info("暂无极端温度的基金")
