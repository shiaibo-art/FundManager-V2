# 行业名称映射
# 将ETF/基金行业名称映射到stock_sector_fund_flow_rank的实际行业名称
SECTOR_NAME_MAPPING = {
    '白酒': '酿酒行业',
    '新能源': '光伏设备',  # 也可以是风电设备、电池等
    '半导体': '半导体',
    '传媒': '文化传媒',
    '煤炭': '煤炭行业',
    '红利': '银行',  # 红利指数主要包含银行等高股息行业
    '医疗': '医疗器械',  # 或医疗服务
    '新能源车': '汽车整车',
    '证券': '证券',
    '银行': '银行',
}


def get_sector_fund_flow_data() -> tuple:
    """
    获取行业资金流向数据
    优先使用 stock_sector_fund_flow_rank 获取详细的资金流向数据

    返回: (数据字典, 调试信息列表)
    """
    debug_info = []
    result = {}

    # 方法1: stock_sector_fund_flow_rank (东方财富行业资金流向排名 - 推荐)
    try:
        df = ak.stock_sector_fund_flow_rank(indicator="今日")
        if df is not None and len(df) > 0:
            debug_info.append(f"[OK] 方法1成功: {len(df)}条数据 (资金流向)")
            result = parse_sector_fund_flow_rank_df(df)
            if result:
                return result, debug_info
    except Exception as e:
        debug_info.append(f"[FAIL] 方法1失败: {str(e)[:60]}")

    # 方法2: stock_sector_spot (东方财富行业板块行情 - 备用)
    try:
        df = ak.stock_sector_spot()
        if df is not None and len(df) > 0:
            debug_info.append(f"[OK] 方法2成功: {len(df)}条数据 (行业板块)")
            result = parse_sector_spot_df(df)
            if result:
                return result, debug_info
    except Exception as e:
        debug_info.append(f"[FAIL] 方法2失败: {str(e)[:60]}")

    debug_info.append("[FAIL] 所有方法均失败")
    return {}, debug_info


def parse_sector_spot_df(df) -> dict:
    """
    解析 stock_sector_spot 返回的行业板块DataFrame

    数据列索引:
    - 1: 行业名称
    - 6: 总成交额
    - 7: 总市值
    """
    if df is None or len(df) == 0:
        return {}

    result = {}

    try:
        # 使用列索引访问数据（避免编码问题）
        name_idx = 1      # 行业名称
        amount_idx = 6    # 总成交额

        # 计算总成交额
        total_amount = df.iloc[:, amount_idx].sum()

        if total_amount == 0:
            return {}

        # 提取每个行业的数据
        for _, row in df.iterrows():
            try:
                sector_name = str(row.iloc[name_idx]).strip()
                amount = float(row.iloc[amount_idx])

                if amount > 0:
                    ratio = (amount / total_amount) * 100

                    result[sector_name] = {
                        'net_inflow': 0,  # stock_sector_spot没有净流入数据
                        'total_amount': amount,
                        'ratio': ratio
                    }
            except Exception as e:
                continue

        return result
    except Exception as e:
        return {}


def parse_sector_fund_flow_rank_df(df) -> dict:
    """
    解析 stock_sector_fund_flow_rank 返回的资金流向DataFrame

    数据列:
    - 名称: 行业/板块名称
    - 今日主力净流入-净额: 主力净流入金额
    - 今日主力净流入-净占比: 主力净流入占比
    - 今日涨跌幅: 涨跌幅
    """
    if df is None or len(df) == 0:
        return {}

    result = {}

    try:
        # 使用列名访问数据
        name_col = '名称'
        net_inflow_col = '今日主力净流入-净额'
        net_ratio_col = '今日主力净流入-净占比'
        change_col = '今日涨跌幅'

        # 计算总净流入绝对值（用于计算占比权重）
        total_abs_inflow = 0
        for _, row in df.iterrows():
            try:
                inflow = float(row[net_inflow_col])
                total_abs_inflow += abs(inflow)
            except:
                continue

        if total_abs_inflow == 0:
            return {}

        # 提取每个行业的数据
        for _, row in df.iterrows():
            try:
                sector_name = str(row[name_col]).strip()
                net_inflow = float(row[net_inflow_col])
                net_ratio = float(row[net_ratio_col]) if net_ratio_col in df.columns else 0
                change_pct = float(row[change_col]) if change_col in df.columns else 0

                # 计算该行业净流入占总净流入绝对值的比例
                flow_ratio = (abs(net_inflow) / total_abs_inflow) * 100

                result[sector_name] = {
                    'net_inflow': net_inflow,
                    'net_ratio': net_ratio,  # API返回的占比
                    'flow_ratio': flow_ratio,  # 基于绝对值计算的占比
                    'change_pct': change_pct,
                    'total_amount': abs(net_inflow)  # 用净流入绝对值作为成交量的代理
                }
            except Exception as e:
                continue

        return result
    except Exception as e:
        return {}


def get_sector_volume_ratio(sector_name: str, fund_flow_data: dict = None) -> dict:
    """
    获取行业资金流向数据

    返回包含成交额占比、净流入、情绪状态等信息的字典
    """
    if not fund_flow_data:
        return {'ratio': 0, 'net_inflow': 0, 'sentiment': '无数据', 'change_pct': 0}

    # 首先尝试使用映射表
    mapped_name = SECTOR_NAME_MAPPING.get(sector_name, sector_name)

    # 精确匹配（使用映射后的名称）
    data = None
    if mapped_name in fund_flow_data:
        data = fund_flow_data[mapped_name]
    elif sector_name in fund_flow_data:
        data = fund_flow_data[sector_name]
    else:
        # 模糊匹配
        for key, val in fund_flow_data.items():
            if sector_name in key or key in sector_name or mapped_name in key or key in mapped_name:
                data = val
                break

    if not data:
        return {'ratio': 0, 'net_inflow': 0, 'sentiment': '无数据', 'change_pct': 0}

    # 根据数据类型选择合适的占比字段
    # 使用 .get() 方法避免 KeyError
    if data.get('flow_ratio') is not None:
        # 使用资金流向计算的占比
        ratio = data['flow_ratio']
    elif data.get('ratio') is not None:
        # 使用成交额占比
        ratio = data['ratio']
    else:
        ratio = 0

    net_inflow = data.get('net_inflow', 0)
    change_pct = data.get('change_pct', 0)

    # 判断情绪状态（根据资金热度）
    if ratio >= 15:
        sentiment = "⚠️ 极度活跃"
    elif ratio >= 10:
        sentiment = "🔥 非常活跃"
    elif ratio >= 5:
        sentiment = "📈 活跃"
    elif ratio >= 2:
        sentiment = "😐 正常"
    else:
        sentiment = "❄️ 冷清"

    return {
        'ratio': ratio,
        'net_inflow': net_inflow,
        'change_pct': change_pct,
        'sentiment': sentiment
    }


def calculate_market_temperature(fund_code: str, fund_name: str, include_volume: bool = False,
                                fund_flow_data: dict = None) -> dict:
    """计算市场温度"""
    try:
        df = get_fund_nav_history(fund_code, period="1年")

        if df is None or len(df) < 60:
            return None

        latest_nav = df.iloc[-1]['nav']

        # 计算涨跌幅
        week_ago_nav = df.iloc[-5]['nav'] if len(df) >= 5 else df.iloc[0]['nav']
        month_ago_nav = df.iloc[-20]['nav'] if len(df) >= 20 else df.iloc[0]['nav']

        week_return = (latest_nav - week_ago_nav) / week_ago_nav * 100
        month_return = (latest_nav - month_ago_nav) / month_ago_nav * 100

        # 价格位置
        min_nav = df['nav'].min()
        max_nav = df['nav'].max()
        price_position = (latest_nav - min_nav) / (max_nav - min_nav) * 100 if max_nav > min_nav else 50

        # 回撤
        df_copy = df.copy()
        df_copy['cummax'] = df_copy['nav'].cummax()
        current_drawdown = (df_copy.iloc[-1]['nav'] - df_copy.iloc[-1]['cummax']) / df_copy.iloc[-1]['cummax'] * 100

        # 趋势强度
        if len(df) >= 20:
            ma20 = df.iloc[-20:]['nav'].mean()
            ma60 = df.iloc[-60:]['nav'].mean() if len(df) >= 60 else df.iloc[0:]['nav'].mean()
            trend_strength = ((latest_nav - ma20) / ma20 * 100 + (ma20 - ma60) / ma60 * 100) / 2
        else:
            trend_strength = 0

        # 成交额占比
        volume_ratio = None
        net_inflow = 0
        volume_heat = 0
        vol_data = None
        if include_volume and fund_flow_data:
            vol_data = get_sector_volume_ratio(fund_name, fund_flow_data)
            volume_ratio = vol_data.get('ratio', 0) if vol_data else 0
            net_inflow = vol_data.get('net_inflow', 0) if vol_data else 0

            if volume_ratio >= 40:
                volume_heat = 100
            elif volume_ratio >= 30:
                volume_heat = 80
            elif volume_ratio >= 20:
                volume_heat = 60
            elif volume_ratio >= 15:
                volume_heat = 40
            elif volume_ratio >= 10:
                volume_heat = 20
            else:
                volume_heat = 0

        # 综合温度
        return_score = (week_return * 0.3 + month_return * 0.7) / 10 + 50
        return_score = max(0, min(100, return_score))

        position_score = price_position
        trend_score = max(0, min(100, 50 + trend_strength * 5))
        drawdown_score = max(0, min(100, 50 + current_drawdown))

        if include_volume and volume_ratio is not None and volume_ratio > 0:
            temperature = (
                return_score * 0.35 +
                position_score * 0.20 +
                trend_score * 0.15 +
                drawdown_score * 0.15 +
                volume_heat * 0.15
            )
        else:
            temperature = (
                return_score * 0.40 +
                position_score * 0.25 +
                trend_score * 0.20 +
                drawdown_score * 0.15
            )

        # 热度等级
        if temperature < 15:
            heat_level = "冰冷"
            icon = "🥶"
        elif temperature < 30:
            heat_level = "寒冷"
            icon = "🧊"
        elif temperature < 45:
            heat_level = "凉爽"
            icon = "🌤️"
        elif temperature < 60:
            heat_level = "温和"
            icon = "😊"
        elif temperature < 75:
            heat_level = "炎热"
            icon = "🔥"
        else:
            heat_level = "滚烫"
            icon = "🌋"

        result = {
            'fund_code': fund_code,
            'fund_name': fund_name,
            'temperature': round(temperature, 1),
            'heat_level': heat_level,
            'icon': icon,
            'metrics': {
                'week_return': round(week_return, 2),
                'month_return': round(month_return, 2),
                'price_position': round(price_position, 1),
                'current_drawdown': round(current_drawdown, 2),
                'trend_strength': round(trend_strength, 2)
            }
        }

        if include_volume and volume_ratio is not None and vol_data:
            result['volume_ratio'] = round(volume_ratio, 1)
            result['net_inflow'] = round(net_inflow, 2)
            result['volume_heat'] = volume_heat
            result['volume_sentiment'] = vol_data.get('sentiment', '数据获取中')

        return result
    except Exception as e:
        import traceback
        print(f"Error calculating temperature for {fund_code}: {e}")
        traceback.print_exc()
        return None


